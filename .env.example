# Supabase — găsești aceste valori în Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key — NUMAI pe server, NICIODATĂ în client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# URL-ul aplicației (fără slash la final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret pentru Next.js (generează cu: openssl rand -base64 32)
NEXTAUTH_SECRET=your-random-secret-here
